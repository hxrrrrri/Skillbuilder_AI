generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Auth + RBAC + Tenants ----------
// SQLite has no native enums; role values are validated at the application layer
// via @/lib/auth/roles. Keep strings here for portability.

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String               @default("")
  passwordHash        String               @default("")
  role                String               @default("candidate") // candidate|employer|college_admin|college_member|admin|super_admin
  primaryTenantId     String?
  githubUsername      String?
  image               String?
  emailVerified       DateTime?
  status              String               @default("active") // active|suspended
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  primaryTenant       Tenant?              @relation("UserPrimaryTenant", fields: [primaryTenantId], references: [id])
  memberships         TenantMembership[]
  candidate           Candidate?
  runsCreated         AnalysisRun[]        @relation("RunCreator")
  profilesOwned       PublicProfile[]      @relation("ProfileOwner")
  auditLogs           AuditLog[]
  terminalCommandRuns TerminalCommandRun[] @relation("TerminalCommandActor")
  promptVersions      PromptVersion[]
  employerShortlists  EmployerShortlist[]
  savedSearches       SavedSearch[]
  ownershipChallenges OwnershipChallenge[]
  accounts            Account[]
  sessions            Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tenant {
  id           String             @id @default(cuid())
  slug         String             @unique
  name         String
  kind         String // college|employer|platform
  status       String             @default("active")
  metadata     String? // JSON
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  memberships  TenantMembership[]
  primaryFor   User[]             @relation("UserPrimaryTenant")
  runs         AnalysisRun[]
  auditLogs    AuditLog[]
  cohorts      Cohort[]
  invites      TenantInvite[]
  talentShares TalentPoolShare[]
}

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String // admin|member|mentor|officer
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  tenantId    String?
  action      String
  targetType  String?
  targetId    String?
  metadata    String? // JSON
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id])
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([actorUserId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
}

// ---------- Provider / Agent registry (admin-managed) ----------
// ProviderConfig persists per-provider settings (command, base URL, enabled, last test result).
// AgentConfig persists per-agent selections (provider, model, reasoning budget, fallback).
// Reasoning budget is the generic abstraction (none|low|medium|high|max);
// adapters in @/lib/providers/reasoning.ts map it to provider-native controls.

model ProviderConfig {
  id                String    @id @default(cuid())
  providerId        String    @unique // anthropic_api|claude_cli|codex_cli|ollama|copilot_cli|deterministic
  label             String
  kind              String // api|cli|local|deterministic
  enabled           Boolean   @default(true)
  defaultModel      String?
  baseUrl           String?
  command           String?
  argsTemplate      String? // JSON string[]
  apiKeyEnv         String? // name of env var holding key
  capabilities      String? // JSON: { reasoning, jsonMode, streaming, models? }
  lastTestedAt      DateTime?
  lastTestStatus    String? // ok|fail|unavailable
  lastTestModel     String?
  lastTestRaw       String?
  lastTestJsonOk    Boolean?
  lastTestLatencyMs Int?
  lastTestError     String?
  notes             String?
  // Dynamic model discovery (live CLI/API probing) + admin custom models.
  discoveredModelsJson String? // JSON string[] of last successfully discovered models
  modelsDiscoveredAt   DateTime?
  modelDiscoveryStatus String? // live|cached|static|custom_only|failed
  modelDiscoveryError  String?
  customModelsJson     String? // JSON string[] of admin-added custom models
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model AgentConfig {
  id               String   @id @default(cuid())
  agentName        String   @unique // orchestrator|architecture|code-quality|...
  providerId       String // matches ProviderConfig.providerId
  model            String
  reasoningBudget  String   @default("medium") // none|low|medium|high|max
  temperature      Float    @default(0.2)
  maxTokens        Int      @default(1500)
  jsonMode         Boolean  @default(true)
  fallbackProvider String?
  fallbackModel    String?
  fallbackStrategy String   @default("fail") // retry|fail|skip_optional
  timeoutMs        Int      @default(60000)
  retryCount       Int      @default(1)
  enabled          Boolean  @default(true)
  costTier         String   @default("medium") // low|medium|high
  qualityTier      String   @default("medium") // low|medium|high
  updatedAt        DateTime @updatedAt
}

model PromptVersion {
  id           String   @id @default(cuid())
  agentName    String
  version      Int
  system       String
  instructions String?
  isActive     Boolean  @default(false)
  createdById  String?
  createdAt    DateTime @default(now())
  createdBy    User?    @relation(fields: [createdById], references: [id])

  @@unique([agentName, version])
  @@index([agentName, isActive])
}

// ---------- Existing domain models (Candidate / Repository / AnalysisRun / etc.) ----------

model Candidate {
  id                String                   @id @default(cuid())
  userId            String?                  @unique
  name              String
  email             String?                  @unique
  githubUsername    String?
  createdAt         DateTime                 @default(now())
  user              User?                    @relation(fields: [userId], references: [id])
  repositories      Repository[]
  runs              AnalysisRun[]
  profiles          PublicProfile[]
  cohortMemberships CohortStudent[]
  reverifications   ReVerificationSnapshot[]
}

model Subscription {
  id                   String    @id @default(cuid())
  ownerUserId          String
  tenantId             String?
  plan                 String    @default("free") // free|pro|team|enterprise
  status               String    @default("inactive") // inactive|trialing|active|past_due|canceled
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([ownerUserId])
  @@index([tenantId])
  @@index([status])
}

model ReVerificationSnapshot {
  id            String    @id @default(cuid())
  candidateId   String
  repoId        String
  previousRunId String
  nextRunId     String?
  previousScore Int?
  nextScore     Int?
  deltaJson     String?
  createdAt     DateTime  @default(now())
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([nextRunId])
  @@index([previousRunId])
}

model Cohort {
  id        String          @id @default(cuid())
  tenantId  String
  name      String
  year      Int?
  notes     String?
  createdAt DateTime        @default(now())
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  students  CohortStudent[]
  invites   TenantInvite[]

  @@unique([tenantId, name])
}

model CohortStudent {
  id          String    @id @default(cuid())
  cohortId    String
  candidateId String
  joinedAt    DateTime  @default(now())
  cohort      Cohort    @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([cohortId, candidateId])
}

model TenantInvite {
  id               String    @id @default(cuid())
  tenantId         String
  email            String
  role             String // candidate|college_member|mentor
  cohortId         String?
  token            String    @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdById      String
  createdAt        DateTime  @default(now())
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  cohort           Cohort?   @relation(fields: [cohortId], references: [id])

  @@index([tenantId, email])
}

model TalentPoolShare {
  id          String    @id @default(cuid())
  tenantId    String
  cohortId    String?
  token       String    @unique
  filters     String?
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Repository {
  id              String        @id @default(cuid())
  candidateId     String?
  repoUrl         String
  repoName        String
  owner           String
  primaryLanguage String?
  framework       String?
  analyzedAt      DateTime?
  createdAt       DateTime      @default(now())
  candidate       Candidate?    @relation(fields: [candidateId], references: [id])
  runs            AnalysisRun[]
}

model AnalysisRun {
  id                   String                  @id @default(cuid())
  candidateId          String?
  createdByUserId      String?
  tenantId             String?
  repoId               String
  targetRole           String
  candidateLevel       String?
  jobDescription       String?
  status               String                  @default("pending") // pending|in_progress|running|completed|failed
  statusMessage        String?
  workerId             String?
  heartbeatAt          DateTime?
  attemptCount         Int                     @default(0)
  maxAttempts          Int                     @default(3)
  lastFailureReason    String?
  overallScore         Int?
  roleFit              String?
  verificationLevel    String                  @default("repo_only") // repo_only|repo_interview_verified
  tokenEstimateRaw     Int?
  tokenEstimateUsed    Int?
  validationContract   String? // JSON
  contextPack          String? // JSON
  repoIntelligence     String? // JSON RepoIntelligenceIndex
  validationCoverage   String? // JSON ValidationAssertionResult[]
  validationSummary    String? // JSON AssertionCoverageSummary
  authenticitySignals  String? // JSON AuthenticityOutput
  improvementPlan      String? // JSON ImprovementPlan
  employerVerifier     String? // JSON EmployerVerifier
  aiCollaboration      String? // JSON AICollabEvaluation
  profileSummary       String? // JSON ProfileOutput
  executionMode        String                  @default("api") // api|cli|hybrid|local
  localInstallApproved Boolean                 @default(false)
  terminalEvidence     String? // JSON TerminalEvidence[]
  providerMatrix       String? // JSON role -> provider id
  ownershipStatus      String? // JSON { owner_match, repo_token_verified, self_declared }
  createdAt            DateTime                @default(now())
  completedAt          DateTime?
  candidate            Candidate?              @relation(fields: [candidateId], references: [id])
  createdBy            User?                   @relation("RunCreator", fields: [createdByUserId], references: [id])
  tenant               Tenant?                 @relation(fields: [tenantId], references: [id])
  repository           Repository              @relation(fields: [repoId], references: [id])
  events               AgentEvent[]
  scores               SkillScore[]
  questions            InterviewQuestion[]
  profiles             PublicProfile[]
  skillRuns            SkillRun[]
  evidenceFindings     EvidenceFinding[]
  harnessSnapshot      HarnessContextSnapshot?
  terminalCommandRuns  TerminalCommandRun[]
  ownershipChallenges  OwnershipChallenge[]

  @@index([candidateId])
  @@index([createdByUserId])
  @@index([tenantId])
  @@index([status])
}

model OwnershipChallenge {
  id         String       @id @default(cuid())
  userId     String
  runId      String?
  repoOwner  String
  repoName   String
  tokenHash  String       @unique
  expiresAt  DateTime
  consumedAt DateTime?
  status     String       @default("issued") // issued|linked|consumed|expired
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  run        AnalysisRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([userId, repoOwner, repoName])
  @@index([runId])
  @@index([expiresAt])
}

model EvaluatorSkill {
  id                  String     @id @default(cuid())
  slug                String     @unique
  name                String
  category            String
  version             String
  description         String?
  sourcePath          String
  enabled             Boolean    @default(true)
  riskLevel           String     @default("low")
  requiredInputsJson  String?
  outputSchemaJson    String?
  toolPermissionsJson String?
  candidateSafe       Boolean    @default(true)
  employerSafe        Boolean    @default(true)
  adminOnly           Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  skillRuns           SkillRun[]

  @@index([category])
  @@index([enabled])
}

model SkillRun {
  id                  String            @id @default(cuid())
  runId               String
  skillId             String
  skillVersion        String
  agentId             String?
  providerId          String?
  requestedModel      String?
  actualModel         String?
  status              String
  startedAt           DateTime
  endedAt             DateTime?
  durationMs          Int?
  inputHash           String
  outputHash          String?
  evidenceIdsJson     String?
  promptVersionId     String?
  toolPermissionsJson String?
  tokenUsageJson      String?
  costEstimateJson    String?
  fallbackReason      String?
  retryHistoryJson    String?
  error               String?
  adminTraceJson      String?
  candidateSummary    String?
  employerSummary     String?
  createdAt           DateTime          @default(now())
  run                 AnalysisRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  skill               EvaluatorSkill?   @relation(fields: [skillId], references: [slug])
  evidenceFindings    EvidenceFinding[]

  @@index([runId])
  @@index([skillId])
  @@index([status])
}

model EvidenceFinding {
  id            String              @id @default(cuid())
  runId         String
  skillRunId    String?
  category      String
  claim         String
  evidenceType  String
  filePath      String?
  lineStart     Int?
  lineEnd       Int?
  commitSha     String?
  commandRunId  String?
  confidence    Float
  severity      String?
  candidateSafe Boolean             @default(true)
  employerSafe  Boolean             @default(false)
  publicSafe    Boolean             @default(false)
  adminOnly     Boolean             @default(false)
  redactedText  String
  rawTextHash   String?
  createdAt     DateTime            @default(now())
  run           AnalysisRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  skillRun      SkillRun?           @relation(fields: [skillRunId], references: [id], onDelete: SetNull)
  commandRun    TerminalCommandRun? @relation(fields: [commandRunId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([skillRunId])
  @@index([category])
  @@index([candidateSafe])
  @@index([employerSafe])
  @@index([publicSafe])
}

model HarnessContextSnapshot {
  id                      String      @id @default(cuid())
  runId                   String      @unique
  repoUrl                 String
  repoOwner               String
  repoName                String
  defaultBranch           String?
  commitSha               String?
  fileTreeHash            String?
  selectedFilesHash       String?
  packageManager          String?
  runtimeDetected         String?
  frameworkDetected       String?
  testFrameworkDetected   String?
  lockfileDetected        Boolean     @default(false)
  executionMode           String
  workerMode              String?
  terminalEnabled         Boolean     @default(false)
  sandboxed               Boolean     @default(true)
  evaluatorRuntimeVersion String
  validatorVersion        String
  createdAt               DateTime    @default(now())
  run                     AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model TerminalCommandRun {
  id               String            @id @default(cuid())
  command          String
  args             String?
  cwd              String
  exitCode         Int?
  stdoutSummary    String
  stderrSummary    String
  durationMs       Int
  outputHash       String
  usedFor          String
  ranAt            DateTime
  actorUserId      String?
  runId            String?
  savedAsEvidence  Boolean           @default(false)
  createdAt        DateTime          @default(now())
  actor            User?             @relation("TerminalCommandActor", fields: [actorUserId], references: [id])
  run              AnalysisRun?      @relation(fields: [runId], references: [id], onDelete: Cascade)
  evidenceFindings EvidenceFinding[]

  @@index([actorUserId])
  @@index([runId])
  @@index([savedAsEvidence])
  @@index([ranAt])
}

model AgentEvent {
  id          String      @id @default(cuid())
  runId       String
  agentName   String
  status      String // pending|running|completed|failed
  startedAt   DateTime?
  completedAt DateTime?
  output      String? // JSON Handoff
  notes       String?
  order       Int
  run         AnalysisRun @relation(fields: [runId], references: [id])
}

model SkillScore {
  id             String      @id @default(cuid())
  runId          String
  skillName      String
  score          Int
  confidence     Float       @default(0.8)
  scoreSource    String      @default("llm") // llm|terminal|github_api|local_clone|interview|challenge|deterministic|not_measured
  evidence       String // JSON Evidence[]
  validatorNotes String?
  run            AnalysisRun @relation(fields: [runId], references: [id])
}

model InterviewQuestion {
  id              String      @id @default(cuid())
  runId           String
  question        String
  sourceFile      String?
  lineStart       Int?
  lineEnd         Int?
  expectedSignals String? // JSON string[]
  redFlags        String? // JSON string[]
  scoringRubric   String? // JSON InterviewQuestion.scoring_rubric
  answer          String?
  answerScore     Int?
  feedback        String?
  dimensionScores String? // JSON {communication, debugging, architecture_explanation, testing_reasoning, understanding_of_own_code}
  run             AnalysisRun @relation(fields: [runId], references: [id])
}

model PublicProfile {
  id                   String                  @id @default(cuid())
  candidateId          String?
  ownerUserId          String?
  runId                String
  slug                 String                  @unique
  visibility           String                  @default("public") // public|unlisted|private
  interviewKit         String? // JSON cached employer interview kit
  includeTerminalProof Boolean                 @default(false)
  createdAt            DateTime                @default(now())
  candidate            Candidate?              @relation(fields: [candidateId], references: [id])
  owner                User?                   @relation("ProfileOwner", fields: [ownerUserId], references: [id])
  run                  AnalysisRun             @relation(fields: [runId], references: [id])
  shortlistItems       EmployerShortlistItem[]

  @@index([ownerUserId])
  @@index([visibility])
}

model EmployerShortlist {
  id          String                  @id @default(cuid())
  ownerUserId String
  tenantId    String?
  name        String
  notes       String?
  createdAt   DateTime                @default(now())
  owner       User                    @relation(fields: [ownerUserId], references: [id])
  items       EmployerShortlistItem[]

  @@index([ownerUserId])
}

model EmployerShortlistItem {
  id              String            @id @default(cuid())
  shortlistId     String
  publicProfileId String
  position        Int               @default(0)
  note            String?
  addedAt         DateTime          @default(now())
  shortlist       EmployerShortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  profile         PublicProfile     @relation(fields: [publicProfileId], references: [id])

  @@unique([shortlistId, publicProfileId])
}

model SavedSearch {
  id          String   @id @default(cuid())
  ownerUserId String
  name        String
  query       String
  createdAt   DateTime @default(now())
  owner       User     @relation(fields: [ownerUserId], references: [id])
}

// ---------- SkillProof Command Copilot (AI assistant) ----------
// Two modes: "help" (public, role-aware product guidance) and "admin" (Command
// Copilot with a typed, RBAC-enforced tool registry). Every write tool flows
// through an approval gate (ChatActionApproval) before execution, and each tool
// call is recorded for audit. Implementation lives in src/lib/copilot/*.
// userId / approvedByUserId are stored as plain strings (no FK) so these tables
// stay self-contained and portable; access control is enforced server-side.

model ChatSession {
  id        String         @id @default(cuid())
  userId    String? // null for anonymous public help sessions
  mode      String         @default("help") // help|admin
  role      String? // role captured at session start, for audit
  title     String         @default("New chat")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  ChatMessage[]
  toolCalls ChatToolCall[]

  @@index([userId])
  @@index([mode])
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  role         String // user|assistant|system|tool
  content      String
  metadataJson String? // JSON: provider, model, citations, toolCallId, ...
  createdAt    DateTime    @default(now())
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ChatToolCall {
  id         String              @id @default(cuid())
  sessionId  String
  messageId  String?
  toolName   String
  riskLevel  String // read|write_safe|write_sensitive|destructive|forbidden
  inputJson  String?
  outputJson String?
  status     String              @default("proposed") // proposed|approved|rejected|executed|failed
  error      String?
  createdAt  DateTime            @default(now())
  executedAt DateTime?
  session    ChatSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  approval   ChatActionApproval?

  @@index([sessionId])
  @@index([status])
}

model ChatActionApproval {
  id               String       @id @default(cuid())
  toolCallId       String       @unique
  approvedByUserId String?
  status           String       @default("pending") // pending|approved|rejected|expired
  approvalText     String?
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())
  resolvedAt       DateTime?
  toolCall         ChatToolCall @relation(fields: [toolCallId], references: [id], onDelete: Cascade)

  @@index([status])
}

model ChatKnowledgeSource {
  id            String   @id @default(cuid())
  title         String
  sourceType    String // docs|route|schema|provider|admin_help
  path          String   @unique
  contentHash   String
  lastIndexedAt DateTime @default(now())

  @@index([sourceType])
}
