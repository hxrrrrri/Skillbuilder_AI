{
  "name": "skillproof-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "worker": "tsx src/worker.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "setup:demo": "npm run db:generate && npm run db:push && npm run db:seed-users && npm run db:seed-registry -- --force && npm run db:seed-prompts",
    "setup:e2e": "npm run db:push && npm run db:seed-users && npm run db:seed-registry -- --force && npm run db:seed-prompts",
    "demo": "next dev",
    "demo:worker": "tsx src/worker.ts",
    "db:push": "prisma db push --skip-generate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:validate:postgres": "prisma validate --schema=prisma/schema.postgres.prisma",
    "db:generate:postgres": "prisma generate --schema=prisma/schema.postgres.prisma",
    "db:push:postgres": "prisma db push --skip-generate --schema=prisma/schema.postgres.prisma",
    "db:seed-users": "tsx prisma/seed-users.ts",
    "db:seed-registry": "tsx prisma/seed-registry.ts",
    "db:seed-prompts": "tsx prisma/seed-prompts.ts",
    "db:purge-audit": "tsx prisma/seed-purge-audit.ts",
    "clean:runs": "node scripts/prune-skillproof-runs.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "next": "14.2.18",
    "next-auth": "^4.24.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
