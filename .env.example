# Anthropic Claude API key — required for agent LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Optional GitHub personal access token (public_repo scope)
# Without it: 60 req/hr. With it: 5000 req/hr.
GITHUB_TOKEN=

# SQLite local file db
DATABASE_URL="file:./dev.db"

# Public base URL (used for shareable profile links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Model overrides (droid whispering — different model per role)
MODEL_ORCHESTRATOR=claude-opus-4-7
MODEL_WORKER=claude-sonnet-4-6
MODEL_VALIDATOR=claude-opus-4-7

# Set to "1" to bypass real LLM calls (deterministic mock outputs)
SKILLPROOF_MOCK_LLM=0
