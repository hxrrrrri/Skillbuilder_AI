DATABASE_URL="file:./dev.db"

# Required by NextAuth. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-32-byte-random-string"
# Optional — defaults to http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# Optional GitHub OAuth linking/login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional Google OAuth login. Do not use Google email as GitHub ownership proof.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic API provider. Required for `api` mode unless you configure another
# ready real provider and choose `cli`, `hybrid`, or `local`.
ANTHROPIC_API_KEY=

# Optional: raises GitHub REST rate limit 60 -> 5000/hr.
# GITHUB_TOKEN=

# Production terminal execution is blocked unless this is explicitly enabled.
# The terminal is still jailed to .skillproof/runs/<run_id> and allowlisted.
SKILLPROOF_TERMINAL_ENABLED=1

# Set to 1 when running `npm run worker` so API requests enqueue work instead
# of executing missions in-process.
SKILLPROOF_WORKER_MODE=0

# Enable the versioned evaluator skill runtime. When disabled, legacy agents can
# still run, but SkillRun/EvidenceFinding provenance will be incomplete.
SKILLPROOF_EVALUATOR_RUNTIME_ENABLED=1

# Public report export is role-safe and redacted. Set to 0 to disable public
# profile report downloads in a hosted prototype.
SKILLPROOF_PUBLIC_REPORTS_ENABLED=1

# Optional model overrides per role.
MODEL_ORCHESTRATOR=claude-opus-4-7
MODEL_WORKER=claude-sonnet-4-6
MODEL_VALIDATOR=claude-opus-4-7

# Used when building public profile URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Provider registry notes:
# Run `npm run db:seed-registry` after `npm run db:push`.
# The DB registry is the primary runtime source; skillproof.local.json is only
# a local fallback/override when DB rows are unavailable.
#
# Real provider setup:
# - Codex CLI: npm install -g @openai/codex && codex
# - Claude CLI: install Claude Code && claude auth login
# - GitHub Copilot CLI: install modern `copilot` binary && copilot login
# - Ollama: start Ollama and explicitly pull a configured model, e.g.
#   ollama pull qwen2.5-coder
# Then open /admin/providers/health and run provider JSON contract tests.
#
