DATABASE_URL="file:./dev.db"

# Real Claude mode — set this, or leave it unset to use heuristic/mock mode.
ANTHROPIC_API_KEY=

# Force heuristic/mock mode even if ANTHROPIC_API_KEY is set.
# SKILLPROOF_MOCK_LLM=1

# Optional: raises GitHub REST rate limit 60 -> 5000/hr.
# GITHUB_TOKEN=

# Optional model overrides per role.
MODEL_ORCHESTRATOR=claude-opus-4-7
MODEL_WORKER=claude-sonnet-4-6
MODEL_VALIDATOR=claude-opus-4-7

# Used when building public profile URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
